# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Brevo (email delivery — contact form + order confirmations)
# Get from: app.brevo.com → Account → SMTP & API → API Keys
BREVO_API_KEY=your-brevo-api-key-here

# Stripe (payments)
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Supabase (database + file storage)
# Get from: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Download token signing (used for secure download links)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOWNLOAD_TOKEN_SECRET=your-random-secret-here-minimum-32-chars
